{
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "module": "preserve",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "esModuleInterop": true,
        "types": ["node", "bun"],
        "outDir": "bin",
        "paths": { // for bun
            "#skyware/bot": ["./src/@skyware/bot/src/index.js"],
            "#skyware/labeler": ["./src/@skyware/labeler/src/index.js"],
            "#skyware/bot/*": ["./src/@skyware/bot/src/*"],
            "#skyware/labeler/*": ["./src/@skyware/labeler/src/*"]
        }
    },
    "include": ["src/**/*.ts", "src/utils/id128/src/common/byte-array.js"],
    "exclude": ["node_modules"]
}
