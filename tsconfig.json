{
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "types": ["node"],
        "outDir": "bin",
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
